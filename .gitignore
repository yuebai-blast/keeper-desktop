# ── Python / sidecar ──
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
# ── PyInstaller 冻结产物（spec 入库，构建产物不入库）──
sidecar/build/
sidecar/dist/

# ── Node / 前端 ──
node_modules/
dist/
.vite/

# ── Tauri / Rust ──
target/
apps/desktop/src-tauri/target/
# Tauri sidecar 构建期产物（按 target triple 命名的副本，体积大，不入库）
apps/desktop/src-tauri/binaries/

# ── 模型权重缓存（体积大，不入库；首次运行自动下载）──
.cache/
models/

# ── 本地配置 / 密钥（API key 等绝不入库）──
.env
.env.local
*.key

# ── 操作系统 ──
.DS_Store
Thumbs.db

# ── IDE / 编辑器 / 工具 ──
.idea/
.vscode/
.claude/

# ── 打包产物 ──
*.dmg
*.msi
*.AppImage
*.deb

# ── 临时文件 ──
.todolist.md
