{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/keeper-sidecar", "sidecar": true, "args": ["--port", "8761"] }]
    }
  ]
}
